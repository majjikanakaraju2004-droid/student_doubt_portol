# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_NAME=doubt_system
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email — required for real password-reset emails (Gmail: use an App Password, not your normal password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your.email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your.email@gmail.com

# Password reset links in email (must match your Vite dev URL)
FRONTEND_URL=http://localhost:5173

# SLA: hours before a pending doubt is flagged overdue
DOUBT_SLA_HOURS=24

# AI similarity threshold (0.0–1.0)
AI_SIMILARITY_THRESHOLD=0.6
